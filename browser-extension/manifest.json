{
  "manifest_version": 2,
  "name": "Link Capture",
  "version": "1.0",
  "description": "Send current page to lispy link capture service",

  "permissions": [
    "activeTab",
    "http://localhost:8080/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_title": "Save Link"
  }
}
